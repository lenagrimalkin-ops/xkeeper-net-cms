{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Услуга «под ключ» для лизинга (10 типовых страниц)"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "summary": { "type": "text" },
    "whenNeeded": { "type": "richtext" },
    "whatIncluded": { "type": "richtext" },
    "geography": { "type": "text" },
    "relatedServices": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service",
      "inversedBy": "relatedServices"
    },
    "heroImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.text-media",
        "blocks.advantages",
        "blocks.cases",
        "blocks.cta-block",
        "blocks.faq",
        "blocks.form"
      ]
    }
  }
}
